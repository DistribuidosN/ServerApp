### =========================================================================
###  [ 1 ] AUTH ENDPOINTS
### =========================================================================

### 1.1 Iniciar Sesión (logIn)
POST {{baseUrl}}/auth HTTP/1.1
Content-Type: text/xml; charset=utf-8

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://auth.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:logIn>
         <username>juan</username>
         <password>123456</password>
      </enf:logIn>
   </soapenv:Body>
</soapenv:Envelope>

### 1.2 Registrar Usuario (register)
POST {{baseUrl}}/auth HTTP/1.1
Content-Type: text/xml; charset=utf-8

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://auth.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:register>
         <user>
            <username>nuevo_user_test</username>
            <password>password123</password>
         </user>
      </enf:register>
   </soapenv:Body>
</soapenv:Envelope>

### 1.3 Cerrar Sesión (logOut)
POST {{baseUrl}}/auth HTTP/1.1
Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://auth.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:logOut/>
   </soapenv:Body>
</soapenv:Envelope>

