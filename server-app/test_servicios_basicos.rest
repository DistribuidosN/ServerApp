Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://node.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:uploadImages>
         <imageData>iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8/5+hHgAHggJ/PchI7wAAAABJRU5ErkJggg==</imageData>
         <fileName>test_simple.png</fileName>
         <transformations>
            <name>grayscale</name>
         </transformations>
      </enf:uploadImages>
   </soapenv:Body>
</soapenv:Envelope>

### 3.2 Subir Imagen Completa (Múltiples Filtros)
POST {{baseUrl}}/node HTTP/1.1
Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://node.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:uploadImages>
         <imageData></imageData>
         <fileName>test_completo.png</fileName>
         <transformations>
            <name>inference</name>
         </transformations>
         <transformations>
            <name>blur</name>
         </transformations>
         <transformations>
            <name>grayscale</name>
         </transformations>
         <transformations>
            <name>ocr</name>
         </transformations>
      </enf:uploadImages>
   </soapenv:Body>
</soapenv:Envelope>
