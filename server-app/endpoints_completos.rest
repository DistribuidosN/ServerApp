@token = mock-token-123
@baseUrl = http://localhost:8080/services

### =========================================================================
###  [ 1 ] AUTH ENDPOINT (/auth) - NO REQUIERE TOKEN EXCEPTO LOGOUT
### =========================================================================

### 1.1 Iniciar Sesión (logIn)
POST {{baseUrl}}/auth HTTP/1.1
Content-Type: text/xml; charset=utf-8

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://auth.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:logIn>
         <email>usuario@enfok.com</email>
         <password>secreta123</password>
      </enf:logIn>
   </soapenv:Body>
</soapenv:Envelope>

### 1.2 Registrar Usuario (register)
POST {{baseUrl}}/auth HTTP/1.1
Content-Type: text/xml; charset=utf-8

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://auth.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:register>
         <email>nuevo@enfok.com</email>
         <password>secreta123</password>
         <name>Juan</name>
         <lastName>Perez</lastName>
      </enf:register>
   </soapenv:Body>
</soapenv:Envelope>

### 1.3 Cerrar Sesión (logOut)
POST {{baseUrl}}/auth HTTP/1.1
Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://auth.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:logOut/>
   </soapenv:Body>
</soapenv:Envelope>

### =========================================================================
###  [ 2 ] NODE ENDPOINT (/node) - PROTEGIDO (REQUIERE TOKEN)
### =========================================================================

### 2.1 Obtener Todos los Nodos (getAllNodes)
POST {{baseUrl}}/node HTTP/1.1
Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://node.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:getAllNodes/>
   </soapenv:Body>
</soapenv:Envelope>

### 2.2 Obtener un Nodo Específico (getNode)
POST {{baseUrl}}/node HTTP/1.1
Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://node.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:getNode>
         <nodeId>node-1234</nodeId>
      </enf:getNode>
   </soapenv:Body>
</soapenv:Envelope>

### 2.3 Crear Nodo (createNode)
POST {{baseUrl}}/node HTTP/1.1
Content-Type: text/xml; charset=utf-8
Authorization: Bearer {{token}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:enf="http://node.soap.model.server.enfok/">
   <soapenv:Header/>
   <soapenv:Body>
      <enf:createNode>
         <nodeData>
            <!-- Propiedades del Nodo -->
            <host>192.168.1.100</host>
         </nodeData>
      </enf:createNode>
   </soapenv:Body>
</soapenv:Envelope>

