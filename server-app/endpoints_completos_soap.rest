# =============================================================================
# 4. NODE SERVICE (NodeService)
# Namespace: http://node.soap.model.server.enfok/
# =============================================================================

## 4.1 SUBIR IMAGEN INDIVIDUAL (PIPELINE DINÁMICO)
POST http://{{host}}/NodeService
Content-Type: text/xml
Authorization: {{authToken}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:node="http://node.soap.model.server.enfok/">
   <soapenv:Body>
      <node:uploadImages>
         <imageData>BASE64_BYTES</imageData>
         <fileName>test.png</fileName>
         <transformations>
            <transformation>
               <name>rotate</name>
               <params>{"angle": 90}</params>
            </transformation>
            <transformation>
               <name>grayscale</name>
               <params>{}</params>
            </transformation>
         </transformations>
      </node:uploadImages>
   </soapenv:Body>
</soapenv:Envelope>

###

## 4.2 CARGA MASIVA DE BATCH (JSON DTO)
POST http://{{host}}/NodeService
Content-Type: text/xml
Authorization: {{authToken}}

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" xmlns:node="http://node.soap.model.server.enfok/">
   <soapenv:Body>
      <node:uploadBatch>
         <request>
            <id>batch-001</id>
            <filters>
               <filter>
                  <name>resize</name>
                  <params>{"width": 100, "height": 100}</params>
               </filter>
            </filters>
            <images>
               <image>
                  <id>img-1</id>
                  <name>img.jpg</name>
                  <base64>BASE64_DATA</base64>
               </image>
            </images>
         </request>
      </node:uploadBatch>
   </soapenv:Body>
</soapenv:Envelope>

